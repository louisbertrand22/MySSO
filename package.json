{
  "name": "mysso",
  "version": "3.4.0",
  "description": "Custom SSO implementation with OpenID Connect support",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "node scripts/generateKeys.js && prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test:supabase": "node scripts/testSupabaseConnection.js"
  },
  "keywords": [
    "sso",
    "oauth2",
    "openid-connect",
    "authentication"
  ],
